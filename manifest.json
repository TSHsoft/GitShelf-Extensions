{
  "manifest_version": 3,
  "name": "GitShelf",
  "version": "1.0.0",
  "description": "One-click save GitHub repositories to your personal GitShelf",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "storage",
    "cookies",
    "scripting",
    "offscreen"
  ],
  "host_permissions": [
    "https://github.com/*",
    "https://*.github.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://gitshelf.vercel.app/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*", 
        "http://127.0.0.1/*", 
        "https://gitshelf.vercel.app/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16_grey.png",
      "32": "icons/icon32_grey.png",
      "48": "icons/icon48_grey.png",
      "128": "icons/icon128_grey.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
